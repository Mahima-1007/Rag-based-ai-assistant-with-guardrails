# ─── Application ───────────────────────────────────────────────────────────────
APP_NAME=RAG-AI-Assistant
APP_ENV=development           # development | production
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ─── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rag_user:rag_password@localhost:5432/rag_db

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_QUERY=300
CACHE_TTL_EMBEDDING=3600
CACHE_TTL_RETRIEVAL=180
CACHE_TTL_RESPONSE=300

# ─── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ─── Groq LLM ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=mixtral-8x7b-32768
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.1

# ─── Embeddings ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ─── Chunking ───────────────────────────────────────────────────────────────────
PARENT_CHUNK_SIZE=1000
PARENT_CHUNK_OVERLAP=200
CHILD_CHUNK_SIZE=256
CHILD_CHUNK_OVERLAP=50

# ─── Retrieval ──────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANKER_TOP_K=5
SIMILARITY_THRESHOLD=0.35
CONFIDENCE_HIGH_THRESHOLD=0.70
CONFIDENCE_MEDIUM_THRESHOLD=0.40

# ─── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
